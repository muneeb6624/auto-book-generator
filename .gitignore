# Dependencies
node_modules/

# Environment & secrets (never commit)
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Runtime / generated output
outputs/*
!outputs/.gitkeep
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE & editor
.idea/
.vscode/*
!.vscode/extensions.json
.cursor/

# Test / coverage
coverage/
.nyc_output/

# Build artifacts
dist/
build/

# Markdown — only README.md is tracked (everything else *.md is ignored)
*.md
!README.md

# Frontend
frontend/node_modules/
frontend/

outputs/