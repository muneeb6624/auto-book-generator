{
  "name": "Book API Webhook to Express",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "book-outline",
        "responseMode": "lastNode",
        "options": {}
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 300],
      "id": "webhook-node"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=http://host.docker.internal:3000/api/books/{{ $json.body.bookId }}/outline/generate",
        "options": {}
      },
      "name": "HTTP_Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [460, 300],
      "id": "http-node"
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{ "node": "HTTP_Request", "type": "main", "index": 0 }]]
    }
  },
  "pinData": {},
  "settings": { "executionOrder": "v1" }
}
